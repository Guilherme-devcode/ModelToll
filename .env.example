# ModelToll Environment Configuration
# Copy this to .env and fill in the values

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=ModelToll
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-32-character-string

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
WORKERS=1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://modeltoll:modeltoll@localhost:5432/modeltoll

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Scrubber ──────────────────────────────────────────────────────────────────
SCRUBBER_ENABLED=true
CUSTOM_PATTERNS_PATH=config/custom_patterns.json

# ── Model Router ──────────────────────────────────────────────────────────────
MODEL_ROUTING_CONFIG_PATH=config/model_routing.json
DEFAULT_APPROVED_MODEL=gpt-4o-mini

# ── Cost Arbitrage ────────────────────────────────────────────────────────────
SAVINGS_SHARE_PERCENT=20.0

# ── Admin API ─────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-admin-key
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
